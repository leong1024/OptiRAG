# Google AI (Gemini embeddings + Gemma / Gemini for generation and RAGAS judges)
GEMINI_API_KEY=

# Pinecone
PINECONE_API_KEY=
PINECONE_INDEX_HOST=
# If unset, the first (dimension, metric) is bound to this host (empty registry only).
# For multiple (dim, metric) pairs: set OPTIRAG_PINECONE_AUTO_CREATE=true or fill artifacts/pinecone_index_registry.json
# with keys like "3072:cosine" -> "https://....pinecone.io"
# OPTIRAG_PINECONE_AUTO_CREATE=false
# OPTIRAG_PINECONE_CLOUD=aws
# OPTIRAG_PINECONE_REGION=us-east-1
# Optional: index name prefix for auto-created physical indexes (default: optirag)
# OPTIRAG_PINECONE_INDEX_PREFIX=optirag
# OPTIRAG_PINECONE_INDEX_REGISTRY_PATH=

# Optional tracing
# LANGCHAIN_TRACING_V2=false
# LANGCHAIN_API_KEY=

# Defaults
# OPTIRAG_DATA_DIR=./data
# OPTIRAG_ARTIFACTS_DIR=./artifacts
